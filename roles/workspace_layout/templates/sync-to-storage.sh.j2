#!/usr/bin/env bash
# Generated by the researchcloud-ddp-transcribe component — do not edit.
# Pushes the boot-disk hot path to the durable storage backend (ADR 0032).
# Called automatically by run-pipeline*.sh at the end of a `process` run; also
# safe to run by hand (e.g. to checkpoint a long run during a pause).
set -euo pipefail

# Serialize concurrent syncs: on a 2-GPU workspace both run-pipeline instances
# call this at the end of their `process` runs and would otherwise race on the
# shared state snapshot (concurrent sqlite .backup to one file corrupts it).
exec 9>"{{ state_dir }}/.sync.lock"
flock 9

{% if storage_backend == 'yoda' %}
# Yoda (iRODS) sink via GoCommands. Snapshot the state DB locally first (a
# consistent online .backup, NOT a raw WAL copy), then push transcripts + the
# snapshot through the shared yoda-sync.sh.
sqlite3 "{{ state_dir }}/state.sqlite" ".backup '{{ state_dir }}/state-snapshot.sqlite'"
YODA_COLLECTION="{{ yoda_collection }}" \
YODA_TRANSCRIPTS_LOCAL="{{ work_dir }}/transcripts" \
YODA_STATE_SNAPSHOT="{{ state_dir }}/state-snapshot.sqlite" \
  "{{ pipeline_home }}/yoda-sync.sh" push
echo "synced (yoda): transcripts + state -> {{ yoda_collection }}"
{% else %}
# Mount-based sink (src-volume / mounted Research Drive).
# Durable transcript sink: rsync the sharded NN/ tree boot disk -> volume.
# write-once atomic artifacts make this safe even if a run is still active.
rsync -a "{{ work_dir }}/transcripts/" "{{ storage_path }}/transcripts/"

# Consistent online snapshot of the state DB (NOT a raw copy of a live WAL),
# so a rebuilt workspace can resume via restore-from-storage.sh.
sqlite3 "{{ state_dir }}/state.sqlite" ".backup '{{ storage_path }}/state-snapshot.sqlite'"

echo "synced: transcripts -> {{ storage_path }}/transcripts; state -> {{ storage_path }}/state-snapshot.sqlite"
{% endif %}
