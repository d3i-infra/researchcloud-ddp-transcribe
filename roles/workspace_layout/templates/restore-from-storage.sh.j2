#!/usr/bin/env bash
# Generated by the researchcloud-ddp-transcribe component — do not edit.
# Rehydrate this (fresh) workspace from the durable storage backend so a dead
# workspace is resumable (ADR 0032): restore the state snapshot + transcripts,
# then claim_next resumes where it left off and ADR 0008 makes re-attempts
# idempotent. Run ONCE on a rebuilt workspace, before the first `process`.
set -euo pipefail

{% if storage_backend == 'yoda' %}
# Yoda (iRODS) seed via GoCommands. Pull the state snapshot (straight to the
# live state DB) + any prior transcripts, then the inbox so `ingest` has input
# (the mount backends read inbox in place; Yoda has no mount, so it is pulled).
YODA_COLLECTION="{{ yoda_collection }}" \
YODA_STATE_SNAPSHOT="{{ state_dir }}/state.sqlite" \
YODA_TRANSCRIPTS_LOCAL="{{ work_dir }}/transcripts" \
  "{{ pipeline_home }}/yoda-sync.sh" pull-resume
YODA_COLLECTION="{{ yoda_collection }}" \
YODA_INBOX_LOCAL="{{ work_dir }}/inbox" \
  "{{ pipeline_home }}/yoda-sync.sh" pull-inbox
{% else %}
if [ -f "{{ storage_path }}/state-snapshot.sqlite" ]; then
  cp "{{ storage_path }}/state-snapshot.sqlite" "{{ state_dir }}/state.sqlite"
  echo "restored state DB from {{ storage_path }}/state-snapshot.sqlite"
else
  echo "no state snapshot on the volume — nothing to restore (fresh batch)"
fi

if [ -d "{{ storage_path }}/transcripts" ]; then
  rsync -a "{{ storage_path }}/transcripts/" "{{ work_dir }}/transcripts/"
  echo "restored transcripts to {{ work_dir }}/transcripts"
fi
{% endif %}
