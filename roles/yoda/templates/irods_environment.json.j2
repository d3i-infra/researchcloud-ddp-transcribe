{
  "irods_host": "{{ yoda_host }}",
  "irods_port": {{ yoda_port }},
  "irods_home": "{{ yoda_home }}",
  "irods_user_name": "{{ yoda_user }}",
  "irods_zone_name": "{{ yoda_zone }}",
